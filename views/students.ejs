<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDU-ID SaaS | Student Directory</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <header>
            <h1>Student Management</h1>
            <nav style="display: flex; gap: 1.5rem;">
                <a href="/schools" style="color: var(--text-muted); text-decoration: none; font-weight: 500;">Schools</a>
                <a href="/users" style="color: var(--text-muted); text-decoration: none; font-weight: 500;">Users</a>
                <a href="/students" style="color: var(--primary); text-decoration: none; font-weight: 600;">Students</a>
            </nav>
        </header>

        <!-- Register Student -->
        <section class="card">
            <h2 style="margin-bottom: 1.5rem; font-size: 1.25rem;">Register New Student</h2>
            <form action="/students/add" method="POST" enctype="multipart/form-data">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="rollNo">Roll Number</label>
                        <input type="text" id="rollNo" name="rollNo" required>
                    </div>
                    <div class="form-group">
                        <label for="class">Class / Grade</label>
                        <input type="text" id="class" name="class" placeholder="e.g. 10-A" required>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label for="bloodGroup">Blood Group</label>
                        <input type="text" id="bloodGroup" name="bloodGroup" placeholder="e.g. O+">
                    </div>
                    <div class="form-group">
                        <label for="schoolId">School</label>
                        <select id="schoolId" name="schoolId" required>
                            <option value="">-- Assign School --</option>
                            <% schools.forEach(school => { %>
                                <option value="<%= school._id %>"><%= school.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="studentImage">Student Photo</label>
                        <input type="file" id="studentImage" name="studentImage" accept="image/*" required>
                    </div>
                </div>
                <div style="margin-top: 1.5rem; text-align: right;">
                    <button type="submit">Complete Registration</button>
                </div>
            </form>
        </section>

        <!-- Students Directory -->
        <section class="card" style="padding: 1rem 0;">
            <div style="padding: 0 2rem 1rem 2rem;">
                <h2 style="font-size: 1.25rem;">Student Records</h2>
            </div>
            <table>
                <thead>
                    <tr>
                        <th style="padding-left: 2rem;">Photo</th>
                        <th>Name</th>
                        <th>Roll No</th>
                        <th>QR Code</th>
                        <th>Class</th>
                        <th>School</th>
                        <th style="padding-right: 2rem;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (students.length > 0) { %>
                        <% students.forEach(student => { %>
                            <tr>
                                <td style="padding-left: 2rem;">
                                    <img src="<%= student.imgUrl %>" alt="Profile" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid var(--border);">
                                </td>
                                <td style="font-weight: 600;"><%= student.name %></td>
                                <td style="color: var(--text-muted);"><%= student.rollNo %></td>
                                <td>
                                    <img src="<%= student.qrCode %>" alt="QR" style="width: 50px; height: 50px;">
                                    <br>
                                    <a href="<%= student.qrCode %>" download="<%= student.rollNo %>_QR.png" style="font-size: 0.6rem; color: var(--primary);">Download</a>
                                </td>
                                <td><%= student.class %></td>
                                <td style="color: var(--text-muted); font-size: 0.85rem;"><%= student.schoolId.name %></td>
                                <td style="padding-right: 2rem;">
                                    <span class="badge badge-active">Active</span>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                No student records found.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </section>
    </div>
</body>
</html>
