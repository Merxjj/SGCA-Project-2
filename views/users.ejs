<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDU-ID SaaS | Manage Users</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <header>
            <h1>User & Access Management</h1>
            <nav>
                <a href="/schools" style="color: var(--primary); text-decoration: none; font-weight: 500;">Back to Schools</a>
            </nav>
        </header>

        <!-- Add User Section -->
        <section class="card">
            <h2 style="margin-bottom: 1.5rem; font-size: 1.25rem;">Create New User</h2>
            <form action="/users/add" method="POST">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" placeholder="john@example.com" required>
                    </div>
                    <div class="form-group">
                        <label for="password">Initial Password</label>
                        <input type="password" id="password" name="password" placeholder="••••••••" required>
                    </div>
                </div>
                <div class="form-grid" style="margin-bottom: 0;">
                    <div class="form-group">
                        <label for="role">System Role</label>
                        <select id="role" name="role" required onchange="toggleSchoolSelect()">
                            <option value="super_admin">Super Admin</option>
                            <option value="school_admin">School Admin</option>
                            <option value="teacher">Teacher</option>
                            <option value="student">Student</option>
                            <option value="security_guard">Security Guard</option>
                        </select>
                    </div>
                    <div class="form-group" id="schoolGroup" style="display: none;">
                        <label for="schoolId">Assign to School</label>
                        <select id="schoolId" name="schoolId">
                            <option value="">-- Select School --</option>
                            <% if (schools.length > 0) { %>
                                <% schools.forEach(school => { %>
                                    <option value="<%= school._id %>"><%= school.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                </div>
                <div style="margin-top: 1.5rem; text-align: right;">
                    <button type="submit">Create User Account</button>
                </div>
            </form>
        </section>

        <!-- Users List -->
        <section class="card" style="padding: 1rem 0;">
            <div style="padding: 0 2rem 1rem 2rem;">
                <h2 style="font-size: 1.25rem;">System Users</h2>
            </div>
            <table>
                <thead>
                    <tr>
                        <th style="padding-left: 2rem;">Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>School</th>
                        <th style="padding-right: 2rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (users.length > 0) { %>
                        <% users.forEach(user => { %>
                            <tr>
                                <td style="padding-left: 2rem; font-weight: 600;"><%= user.name %></td>
                                <td style="color: var(--text-muted);"><%= user.email %></td>
                                <td><span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;"><%= user.role.replace('_', ' ') %></span></td>
                                <td style="color: var(--text-muted);">
                                    <%= user.schoolId ? user.schoolId.name : 'All (System)' %>
                                </td>
                                <td style="padding-right: 2rem;">
                                    <form action="/users/delete/<%= user._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Truly delete this user?')">
                                        <button type="submit" style="background: #ef4444; padding: 0.4rem 0.8rem; font-size: 0.75rem;">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                No users found in the system.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </section>
    </div>

    <script>
        function toggleSchoolSelect() {
            const role = document.getElementById('role').value;
            const schoolGroup = document.getElementById('schoolGroup');
            const schoolInput = document.getElementById('schoolId');
            
            if (role === 'super_admin') {
                schoolGroup.style.display = 'none';
                schoolInput.required = false;
            } else {
                schoolGroup.style.display = 'flex';
                schoolInput.required = true;
            }
        }
        // Initialize state
        toggleSchoolSelect();
    </script>
</body>
</html>
