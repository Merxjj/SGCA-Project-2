<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register Institution | EDU-ID SaaS</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background: radial-gradient(circle at top right, #6366f1, #a855f7);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .signup-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 2.5rem;
            border-radius: 1.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            width: 100%;
            max-width: 600px;
        }
        .signup-header { text-align: center; margin-bottom: 2rem; }
        .signup-header h1 { font-size: 1.75rem; background: linear-gradient(135deg, #6366f1, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .section-title { font-size: 0.75rem; text-transform: uppercase; color: var(--primary); font-weight: 700; margin-bottom: 1rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; }
        button { width: 100%; padding: 1rem; font-size: 1rem; margin-top: 1rem; }
    </style>
</head>
<body>
    <div class="signup-card">
        <div class="signup-header">
            <h1>Onboard Your Institution</h1>
            <p style="color: var(--text-muted);">Join the EDU-ID digital ecosystem</p>
        </div>

        <form action="/signup" method="POST">
            <div class="section-title">School Details</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>School Name</label>
                    <input type="text" name="schoolName" placeholder="e.g. Stanford University" required>
                </div>
                <div class="form-group">
                    <label>Inquiry Email</label>
                    <input type="email" name="contactEmail" placeholder="info@uni.edu" required>
                </div>
            </div>
            <div class="form-group" style="margin-bottom: 2rem;">
                <label>Address</label>
                <input type="text" name="address" placeholder="Campus Location" required>
            </div>

            <div class="section-title">Admin Account</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Admin Name</label>
                    <input type="text" name="adminName" placeholder="Registrar Name" required>
                </div>
                <div class="form-group">
                    <label>Login Password</label>
                    <input type="password" name="password" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit">Create Marketplace Account</button>
        </form>
        
        <p style="text-align: center; margin-top: 1.5rem; font-size: 0.875rem; color: var(--text-muted);">
            Already registered? <a href="/login" style="color: var(--primary); font-weight: 600; text-decoration: none;">Sign In</a>
        </p>
    </div>
</body>
</html>
